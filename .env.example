# ───────────────────────────────────────────────────────────
# ServiceHub — переменные окружения (скопируйте в .env)
# ───────────────────────────────────────────────────────────

# --- База данных (используется контейнерами db и wordpress) ---
DB_NAME=servicehub
DB_USER=servicehub
DB_PASSWORD=servicehub
DB_ROOT_PASSWORD=root

# --- WordPress ---
# Внешний порт, на котором будет доступен WP (admin + GraphQL endpoint)
WP_PORT=8080
WP_URL=http://localhost:8080
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@servicehub.test
WP_TITLE=ServiceHub

# Соль для JWT (понадобится в Спринте 5, задаём заранее)
GRAPHQL_JWT_AUTH_SECRET_KEY=change-me-to-a-long-random-string

# --- Next.js (web) ---
WEB_PORT=3000
# URL GraphQL-эндпоинта WordPress, который дёргает фронт
NEXT_PUBLIC_WORDPRESS_URL=http://localhost:8080
WORDPRESS_GRAPHQL_ENDPOINT=http://localhost:8080/graphql
# Секрет для вебхука ревалидации (WP -> Next revalidateTag), Спринт 1
REVALIDATE_SECRET=change-me-revalidate-secret
